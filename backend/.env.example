# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/anithing

# ─── better-auth ──────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=replace_me_with_a_32_plus_char_secret
# The canonical URL of this backend (used by better-auth for callbacks)
BETTER_AUTH_URL=http://localhost:5000

# ─── Frontend (CORS) ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Cloudinary (optional — leave blank to use local /uploads stub) ───────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
